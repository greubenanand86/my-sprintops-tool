# Azure DevOps Server-Side Configuration
# IMPORTANT: These variables are used by Netlify Functions. 
# Do NOT prefix with VITE_ as that would expose them to the frontend.

# The full URL of your Azure DevOps organization
ADO_ORG_URL="https://headstreamtech.visualstudio.com/"

# The default project name
ADO_PROJECT="Performer"

# Your Personal Access Token (PAT)
# Required Scopes: Work Items (Read & Write), Project and Team (Read)
ADO_PAT="YOUR_API_KEY"
