# SprintOps Console - Environment Template
# Copy this file to .env for local development

# --- Azure DevOps (Server-Side Only) ---
# These must be set in Netlify UI for production
ADO_ORG_URL="https://dev.azure.com/your-org-name/"
ADO_PROJECT="YourProjectName"
ADO_PAT="your-personal-access-token-here"

# --- Security Notes ---
# 1. Never prefix ADO_PAT with VITE_.
# 2. Never commit your actual .env file to source control.
# 3. After changing these variables in Netlify, you MUST trigger a new deploy.
